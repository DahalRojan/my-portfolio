dist/
.astro/
.output/
.vercel/
.wrangler/

# -- Dependencies --
node_modules/
.pnpm-store/
pnpm-debug.log*
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# -- Local tooling / agent state (never ship) --
.claude/
