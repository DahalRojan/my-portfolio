---
import Listing from '../../layouts/Listing.astro';
import EssayCard from '../../components/EssayCard.astro';
import { getCollection } from 'astro:content';
import { minutesOf } from '../../lib/reading';
import { entrySlug, filterByLang } from '../../lib/content';
import { useTranslations, localePath } from '../../i18n/utils';

const lang = 'en' as const;
const t = useTranslations(lang);

const posts = filterByLang(
  await getCollection('writing', ({ data }) => !data.draft),
  lang
).sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
---

<Listing
  title={t('writing.title')}
  description={t('writing.intro')}
  kicker={t('writing.kicker')}
  intro={t('writing.intro')}
>
  <div>
    {
      posts.map((post) => (
        <EssayCard
          href={localePath(`/writing/${entrySlug(post)}`, lang)}
          title={post.data.title}
          dek={post.data.dek}
          date={post.data.date}
          minutes={minutesOf(post.body ?? '')}
        />
      ))
    }
    <div class="border-t border-[var(--color-rule)]" />
  </div>

  <p class="mt-10 text-[14px] text-[var(--color-ink-soft)]">
    {t('writing.subscribe.before')}<a class="link-rule text-[var(--color-rust)]" href="/rss.xml">{t('writing.subscribe.rss')}</a>{t('writing.subscribe.middle')}<a class="link-rule" href="https://www.linkedin.com/in/rojandahal/" target="_blank" rel="noopener noreferrer">{t('writing.subscribe.linkedin')}</a>{t('writing.subscribe.after')}
  </p>
</Listing>
