---
import Listing from '../../layouts/Listing.astro';
import WorkCard from '../../components/WorkCard.astro';
import { getCollection } from 'astro:content';
import { entrySlug, filterByLang } from '../../lib/content';
import { useTranslations, localePath } from '../../i18n/utils';

const lang = 'en' as const;
const t = useTranslations(lang);

const projects = filterByLang(
  await getCollection('work', ({ data }) => !data.draft),
  lang
).sort((a, b) => a.data.order - b.data.order);
---

<Listing
  title={t('work.title')}
  description={t('work.intro')}
  kicker={t('work.kicker')}
  intro={t('work.intro')}
>
  <div>
    {
      projects.map((p) => (
        <WorkCard
          href={localePath(`/work/${entrySlug(p)}`, lang)}
          title={p.data.title}
          role={p.data.role}
          period={p.data.period}
          summary={p.data.summary}
          stack={p.data.stack}
        />
      ))
    }
    <div class="border-t border-[var(--color-rule)]" />
  </div>
</Listing>
