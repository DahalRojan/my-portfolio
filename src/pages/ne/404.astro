---
import Base from '../../layouts/Base.astro';
import { useTranslations, localePath } from '../../i18n/utils';

const lang = 'ne' as const;
const t = useTranslations(lang);
---

<Base title="भेटिएन" noindex>
  <section class="container-x py-32 sm:py-48">
    <div class="measure" data-reveal>
      <p class="mono text-[12px] uppercase tracking-[0.18em] text-[var(--color-rust)]">
        {t('404.kicker')}
      </p>
      <h1 class="display mt-3 text-[clamp(2.6rem,5vw+1rem,4.5rem)]">
        {t('404.title.before')}<span class="display-italic">{t('404.title.italic')}</span>{t('404.title.after')}
      </h1>
      <p class="dek mt-6">
        {t('404.dek')}
      </p>
      <p class="mt-10 flex flex-wrap gap-x-8 gap-y-2 text-[14px] uppercase tracking-[0.14em]">
        <a href={localePath('/', lang)} class="link-rule text-[var(--color-rust)]">{t('404.home')}</a>
        <a href={localePath('/writing', lang)} class="link-grow text-[var(--color-ink-soft)] hover:text-[var(--color-ink)]">{t('nav.writing')}</a>
        <a href={localePath('/work', lang)} class="link-grow text-[var(--color-ink-soft)] hover:text-[var(--color-ink)]">{t('nav.work')}</a>
      </p>
    </div>
  </section>
</Base>
