---
import Post from '../../../layouts/Post.astro';
import { getCollection, render } from 'astro:content';
import { minutesOf } from '../../../lib/reading';
import { entrySlug, filterByLang } from '../../../lib/content';

export async function getStaticPaths() {
  const all = await getCollection('writing', ({ data }) => !data.draft);
  const nePosts = filterByLang(all, 'ne');
  return nePosts.map((post) => ({
    params: { slug: entrySlug(post) },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const minutes = minutesOf(post.body ?? '');
---

<Post
  title={post.data.title}
  dek={post.data.dek}
  date={post.data.date}
  updated={post.data.updated}
  tags={post.data.tags}
  minutes={minutes}
>
  <Content />
</Post>
