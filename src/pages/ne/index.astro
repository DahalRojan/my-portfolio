---
import Base from '../../layouts/Base.astro';
import EssayCard from '../../components/EssayCard.astro';
import WorkCard from '../../components/WorkCard.astro';
import { getCollection } from 'astro:content';
import { minutesOf } from '../../lib/reading';
import { entrySlug, filterByLang, bySlug } from '../../lib/content';
import { useTranslations, localePath } from '../../i18n/utils';

const lang = 'ne' as const;
const t = useTranslations(lang);

const allWritingRaw = await getCollection('writing', ({ data }) => !data.draft);
const enWriting = filterByLang(allWritingRaw, 'en').sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);
const neWriting = filterByLang(allWritingRaw, 'ne').sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
);
const neBySlug = bySlug(neWriting);

// Pick 3 most recent featured essays; prefer the Nepali version when it exists, otherwise English.
const featuredEn = enWriting.filter((p) => p.data.featured).slice(0, 3);
const recentWriting = (featuredEn.length === 3 ? featuredEn : enWriting.slice(0, 3)).map((p) => {
  const slug = entrySlug(p);
  const ne = neBySlug.get(slug);
  return {
    entry: ne ?? p,
    href: ne ? localePath(`/writing/${slug}`, 'ne') : `/writing/${slug}`,
    untranslated: !ne,
  };
});

const allWorkRaw = await getCollection('work', ({ data }) => !data.draft);
const enWork = filterByLang(allWorkRaw, 'en').sort((a, b) => a.data.order - b.data.order);
const neWork = filterByLang(allWorkRaw, 'ne');
const neWorkBySlug = bySlug(neWork);

const featuredEnWork = enWork.filter((p) => p.data.featured).slice(0, 3);
const recentWork = (featuredEnWork.length >= 2 ? featuredEnWork : enWork.slice(0, 3)).map((p) => {
  const slug = entrySlug(p);
  const ne = neWorkBySlug.get(slug);
  return {
    entry: ne ?? p,
    href: ne ? localePath(`/work/${slug}`, 'ne') : `/work/${slug}`,
  };
});
---

<Base title="Rojan Dahal — एआई इन्जिनियर">
  <section class="container-x pt-20 pb-16 sm:pt-28 sm:pb-24">
    <div class="measure-wide" data-reveal>
      <p class="mono text-[12px] uppercase tracking-[0.18em] text-[var(--color-rust)]">
        {t('home.kicker')}
      </p>
      <h1 class="display mt-4 text-[clamp(2.6rem,5vw+1rem,5rem)]">
        {t('home.title.before')}<span class="display-italic">{t('home.title.italic')}</span>{t('home.title.after')}
      </h1>
      <p class="dek mt-7 measure">
        {t('home.dek')}
      </p>

      <div class="mt-10 flex flex-wrap items-baseline gap-x-8 gap-y-3 text-[14px] uppercase tracking-[0.14em]">
        <a href={localePath('/writing', lang)} class="link-grow text-[var(--color-rust)]">
          {t('home.cta.writing')}
        </a>
        <a href={localePath('/work', lang)} class="link-grow text-[var(--color-ink-soft)] hover:text-[var(--color-ink)]">
          {t('home.cta.work')}
        </a>
        <a href={localePath('/about', lang)} class="link-grow text-[var(--color-ink-soft)] hover:text-[var(--color-ink)]">
          {t('home.cta.about')}
        </a>
      </div>
    </div>
  </section>

  <section class="container-x pb-24">
    <header class="mb-8 flex items-baseline justify-between border-t border-[var(--color-rule-strong)] pt-6" data-reveal>
      <h2 class="mono text-[12px] uppercase tracking-[0.18em] text-[var(--color-ink-soft)]">
        {t('section.recentWriting')}
      </h2>
      <a href={localePath('/writing', lang)} class="mono link-grow text-[12px] uppercase tracking-[0.14em] text-[var(--color-rust)]">
        {t('cta.allEssays')}
      </a>
    </header>

    <div>
      {
        recentWriting.map(({ entry, href, untranslated }) => (
          <EssayCard
            href={href}
            title={entry.data.title + (untranslated ? ' (in English)' : '')}
            dek={entry.data.dek}
            date={entry.data.date}
            minutes={minutesOf(entry.body ?? '')}
          />
        ))
      }
      <div class="border-t border-[var(--color-rule)]" />
    </div>
  </section>

  <section class="container-x pb-24">
    <header class="mb-8 flex items-baseline justify-between border-t border-[var(--color-rule-strong)] pt-6" data-reveal>
      <h2 class="mono text-[12px] uppercase tracking-[0.18em] text-[var(--color-ink-soft)]">
        {t('section.selectedWork')}
      </h2>
      <a href={localePath('/work', lang)} class="mono link-grow text-[12px] uppercase tracking-[0.14em] text-[var(--color-rust)]">
        {t('cta.allProjects')}
      </a>
    </header>

    <div>
      {
        recentWork.map(({ entry, href }) => (
          <WorkCard
            href={href}
            title={entry.data.title}
            role={entry.data.role}
            period={entry.data.period}
            summary={entry.data.summary}
            stack={entry.data.stack}
          />
        ))
      }
      <div class="border-t border-[var(--color-rule)]" />
    </div>
  </section>

  <section class="container-x pb-24">
    <div class="grid gap-12 border-t border-[var(--color-rule-strong)] pt-10 sm:grid-cols-[180px_1fr]" data-reveal>
      <h2 class="mono text-[12px] uppercase tracking-[0.18em] text-[var(--color-ink-soft)]">
        {t('section.about')}
      </h2>
      <div class="measure">
        <p class="display text-[clamp(1.6rem,2vw+0.8rem,2.2rem)] leading-tight">
          {t('home.about.body.1')}
        </p>
        <p class="mt-5 text-[17px] leading-[1.7] text-[var(--color-ink-soft)]">
          {t('home.about.body.2')}
        </p>
        <p class="mt-7">
          <a href={localePath('/about', lang)} class="mono link-rule text-[14px] uppercase tracking-[0.14em] text-[var(--color-rust)]">
            {t('cta.readMore')}
          </a>
        </p>
      </div>
    </div>
  </section>

  <section class="container-x pb-32">
    <div class="grid gap-12 border-t border-[var(--color-rule-strong)] pt-10 sm:grid-cols-[180px_1fr]" data-reveal>
      <h2 class="mono text-[12px] uppercase tracking-[0.18em] text-[var(--color-ink-soft)]">
        {t('section.contact')}
      </h2>
      <div class="measure">
        <p class="display text-[clamp(1.6rem,2vw+0.8rem,2.2rem)] leading-tight">
          {t('home.contact.headline.before')}<span class="display-italic">{t('home.contact.headline.italic')}</span>
        </p>
        <p class="mt-6 text-[17px] leading-[1.7] text-[var(--color-ink-soft)]">
          {t('home.contact.body')}
        </p>
        <ul class="mt-7 space-y-2 text-[16px]">
          <li>
            <a class="link-rule text-[var(--color-rust)]" href="mailto:rojandahal1026@gmail.com">
              rojandahal1026@gmail.com
            </a>
          </li>
          <li>
            <a class="link-grow text-[var(--color-ink-soft)] hover:text-[var(--color-ink)]" href="https://www.linkedin.com/in/rojandahal/" target="_blank" rel="noopener noreferrer">
              linkedin.com/in/rojandahal
            </a>
          </li>
          <li>
            <a class="link-grow text-[var(--color-ink-soft)] hover:text-[var(--color-ink)]" href="https://github.com/DahalRojan" target="_blank" rel="noopener noreferrer">
              github.com/DahalRojan
            </a>
          </li>
        </ul>
      </div>
    </div>
  </section>
</Base>
