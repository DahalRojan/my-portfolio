---
import "../styles/global.css";

export interface Props {
  title: string;
  description: string;
}

const { title, description } = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site ?? "https://rojandahal.com").toString();

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: "Rojan Dahal",
  jobTitle: "AI Researcher & ML Engineer",
  email: "mailto:rojandahal1026@gmail.com",
  url: canonical,
  sameAs: [
    "https://www.linkedin.com/in/rojandahal/",
    "https://github.com/DahalRojan",
  ],
  alumniOf: [
    { "@type": "CollegeOrUniversity", name: "Gannon University" },
    { "@type": "CollegeOrUniversity", name: "London Metropolitan University" },
  ],
  knowsAbout: [
    "Machine Learning",
    "Large Language Models",
    "Model Context Protocol",
    "Computer Vision",
    "MLOps",
    "AWS Bedrock",
    "AI Safety",
  ],
};
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#0a0a0b" />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/png" href="/icon2.png" />

    <title>{title}</title>
    <meta name="description" content={description} />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content="/og.svg" />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="/og.svg" />

    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </head>
  <body>
    <slot />
  </body>
</html>
