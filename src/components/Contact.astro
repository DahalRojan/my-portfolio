<section id="output" class="contact">
  <div class="container-x">
    <div class="rail mono text-[11px] tracking-widest uppercase hidden md:block">05 / Output</div>
    <div class="content">
      <p class="anchor display">
        Need someone who builds AI systems that <span class="display-italic accent">behave under pressure</span>?
      </p>

      <a href="mailto:rojandahal1026@gmail.com" class="email display">
        rojandahal1026@gmail.com
      </a>

      <ul class="links mono text-[11px] tracking-widest uppercase">
        <li><a href="https://www.linkedin.com/in/rojandahal/" target="_blank" rel="noopener" class="link link-underline">[ LinkedIn ↗ ]</a></li>
        <li><a href="https://github.com/DahalRojan" target="_blank" rel="noopener" class="link link-underline">[ GitHub ↗ ]</a></li>
        <li><a href="/resume.pdf" target="_blank" rel="noopener" class="link link-underline">[ Resume.pdf ]</a></li>
        <li class="phone">+1 (220) 238-XX-XX</li>
      </ul>
    </div>
  </div>
</section>

<footer class="foot">
  <div class="container-x mono text-[11px] tracking-widest uppercase">
    Built 2026 · Erie, PA · This page just passed its own gatekeeper.
  </div>
</footer>

<style>
  .contact {
    position: relative;
    z-index: 1;
    padding-block: clamp(96px, 20vh, 200px);
    border-top: 1px solid var(--color-border);
    background: color-mix(in srgb, var(--color-bg) 92%, transparent);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
  }
  .rail {
    position: absolute;
    left: clamp(20px, 4vw, 48px);
    top: clamp(96px, 20vh, 200px);
    color: var(--color-ink-mute);
  }
  .content { max-width: 980px; padding-left: clamp(0px, 6vw, 88px); display: grid; gap: clamp(40px, 6vh, 64px); }
  .anchor {
    font-size: clamp(26px, 4vw, 42px);
    line-height: 1.15;
    color: var(--color-ink);
    margin: 0;
    max-width: 760px;
  }
  .accent { color: var(--color-accent); }
  .email {
    display: inline-block;
    font-size: clamp(36px, 7.5vw, 96px);
    line-height: 1;
    letter-spacing: -0.02em;
    color: var(--color-ink);
    word-break: break-all;
    transition: color 220ms;
  }
  .email:hover { color: var(--color-accent); }
  .links {
    list-style: none; margin: 0; padding: 0;
    display: flex; flex-wrap: wrap; gap: 24px;
  }
  .link { color: var(--color-ink-dim); }
  .link:hover { color: var(--color-accent); }
  .phone { color: var(--color-ink-mute); }

  .foot {
    position: relative;
    z-index: 1;
    padding-block: 32px;
    border-top: 1px solid var(--color-border);
    background: var(--color-bg);
    color: var(--color-ink-mute);
  }
</style>
