---
---
<section id="intake" class="hero">
  <div class="container-x relative">
    <div class="rail mono text-[11px] tracking-widest uppercase hidden md:block">00 / Intake</div>

    <div class="hero-content">
      <div class="status mono text-[11px] tracking-widest uppercase">
        <span class="status-dot" aria-hidden="true"></span>
        <span>AI Engineer @ TitanCloud · Open to full-time · mid-2026</span>
      </div>

      <h1 class="hero-name display">
        <span class="glitch">Rojan <span class="display-italic">Dahal</span></span>
      </h1>

      <p class="hero-thesis">
        I build the systems that
        <span class="display-italic accent">gate</span>,
        <span class="display-italic accent">validate</span>, and
        <span class="display-italic accent">govern</span>
        other AI systems.
      </p>

      <p class="hero-sub mono text-[13px] leading-[1.6]">
        AI Engineer @ TitanCloud · MS Data Science @ Gannon · GPA 4.0<br />
        5+ years shipping AI in production. Fintech, manufacturing, agentic systems.
      </p>

      <div class="hero-ctas mono text-[12px] tracking-widest uppercase">
        <a href="#inference" class="cta-primary link-underline">[ Scroll the pipeline ↓ ]</a>
        <a href="/resume.pdf" target="_blank" rel="noopener" class="cta-secondary link-underline">[ Read resume.pdf ]</a>
      </div>
    </div>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100dvh;
    padding-top: clamp(80px, 12vh, 140px);
    padding-bottom: clamp(40px, 8vh, 80px);
    display: flex;
    align-items: center;
    z-index: 1;
  }
  .rail {
    position: absolute;
    top: clamp(80px, 12vh, 140px);
    left: clamp(20px, 4vw, 48px);
    color: var(--color-ink-mute);
  }
  .hero-content {
    max-width: 900px;
    padding-left: clamp(0px, 6vw, 88px);
  }
  .status {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    margin-bottom: clamp(28px, 5vh, 48px);
    color: var(--color-ink-dim);
    padding: 6px 12px;
    border: 1px solid var(--color-border);
    border-radius: 999px;
    background: color-mix(in srgb, var(--color-bg) 60%, transparent);
    backdrop-filter: blur(8px);
  }
  .status-dot {
    width: 8px; height: 8px; border-radius: 999px;
    background: var(--color-accent);
    box-shadow: 0 0 10px var(--color-accent);
    animation: pulse-dot 2s ease-in-out infinite;
  }
  .hero-name {
    font-size: clamp(64px, 12vw, 156px);
    line-height: 0.92;
    letter-spacing: -0.03em;
    color: var(--color-ink);
    margin: 0;
  }
  .glitch {
    display: inline-block;
    animation: chrom-split 1100ms cubic-bezier(0.2, 0.8, 0.2, 1) both;
  }
  @keyframes chrom-split {
    0% {
      opacity: 0;
      transform: translateY(8px);
      text-shadow:
        -6px 0 0 var(--color-accent-coral),
         6px 0 0 var(--color-accent-cool);
      filter: blur(2px);
    }
    35% {
      opacity: 1;
      transform: translateY(0);
      text-shadow:
        -3px 0 0 var(--color-accent-coral),
         3px 0 0 var(--color-accent-cool);
      filter: blur(0.5px);
    }
    70% {
      text-shadow:
        -1px 0 0 var(--color-accent),
         1px 0 0 var(--color-accent-cool);
      filter: blur(0);
    }
    100% {
      text-shadow: none;
      filter: blur(0);
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .glitch { animation: none; }
  }
  .hero-thesis {
    margin-top: clamp(28px, 5vh, 48px);
    max-width: 760px;
    font-size: clamp(20px, 2.8vw, 30px);
    line-height: 1.35;
    color: var(--color-ink);
  }
  .accent { color: var(--color-accent); }
  .hero-sub {
    margin-top: 16px;
    max-width: 660px;
    color: var(--color-ink-dim);
  }
  .hero-ctas {
    margin-top: clamp(40px, 7vh, 64px);
    display: flex; flex-wrap: wrap; gap: 28px;
  }
  .cta-primary { color: var(--color-ink); }
  .cta-secondary { color: var(--color-ink-dim); transition: color 180ms; }
  .cta-secondary:hover { color: var(--color-ink); }
</style>
