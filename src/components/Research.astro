---
import SectionPanel from "./SectionPanel.astro";
import { publications, certifications } from "../content/publications";
---
<SectionPanel
  id="decision"
  number="04"
  label="Decision"
  kicker="L4 — published, peer-reviewed"
  title="Research, cited the way I'd cite it myself."
>
  <div class="stack">
    {publications.map((p, i) => (
      <article class="pub">
        <div class="citation mono">
          <span class="cite-key">[{i + 1}]</span>
          <span class="cite-body">
            {p.authors} ({p.year}).
            <strong>{p.title}</strong>
            <span class="cite-venue"> {p.venue}</span>
            {p.paperNo && <span class="cite-paperno"> Paper No. {p.paperNo}.</span>}
          </span>
          {p.presentedAt && (
            <ul class="presented">
              {p.presentedAt.map((v) => (
                <li><span class="arr">↳</span> {v}</li>
              ))}
            </ul>
          )}
        </div>
        {p.reflection && (
          <p class="reflection">{p.reflection}</p>
        )}
      </article>
    ))}

    <div class="certs">
      <p class="certs-label mono">Certifications</p>
      <ul class="certs-list">
        {certifications.map((c) => (
          <li class="cert-chip mono">{c}</li>
        ))}
      </ul>
    </div>

    <article class="soon">
      <p class="soon-label mono">// soon</p>
      <p class="soon-body">
        Writing on cost-aware LLM systems, MCP, and what it actually takes to put a Bedrock agent in front of users. Not live yet — paper first, posts after.
      </p>
    </article>
  </div>
</SectionPanel>

<style>
  .stack { display: grid; gap: 40px; max-width: 880px; }
  .pub { display: grid; gap: 16px; }

  .citation {
    padding: 22px 24px;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 6px;
    font-size: 13px;
    line-height: 1.65;
    color: var(--color-ink);
  }
  .cite-key { color: var(--color-accent); margin-right: 8px; }
  .citation strong { font-weight: 500; color: var(--color-ink); }
  .cite-venue { color: var(--color-ink-dim); }
  .cite-paperno { color: var(--color-ink-mute); }
  .presented { list-style: none; margin: 12px 0 0; padding-left: 28px; display: grid; gap: 4px; font-size: 12px; color: var(--color-ink-mute); }
  .arr { color: var(--color-accent-dim, #7fc556); margin-right: 4px; }

  .reflection {
    font-size: 16px;
    line-height: 1.7;
    color: var(--color-ink-dim);
    max-width: 700px;
    margin: 0;
  }

  .certs { display: grid; gap: 12px; }
  .certs-label {
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-ink-mute);
  }
  .certs-list { list-style: none; margin: 0; padding: 0; display: flex; flex-wrap: wrap; gap: 6px; }
  .cert-chip {
    font-size: 11px;
    padding: 5px 9px;
    color: var(--color-ink-dim);
    border: 1px solid var(--color-border);
    border-radius: 5px;
    background: color-mix(in srgb, var(--color-surface) 60%, transparent);
  }

  .soon {
    padding: 22px 24px;
    background: rgba(255,255,255,0.015);
    border: 1px dashed var(--color-border);
    border-radius: 6px;
    max-width: 620px;
  }
  .soon-label {
    font-size: 11px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-ink-mute);
    margin: 0 0 10px;
  }
  .soon-body {
    font-size: 14.5px;
    line-height: 1.65;
    color: var(--color-ink-dim);
    margin: 0;
  }
</style>
