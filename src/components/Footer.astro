---
import { getLangFromUrl, useTranslations, localePath } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
const year = new Date().getFullYear();

const links = [
  { href: lang === 'ne' ? '/ne/rss.xml' : '/rss.xml', label: t('footer.rss') },
  {
    href: 'https://www.linkedin.com/in/rojandahal/',
    label: t('footer.linkedin'),
    external: true,
  },
  {
    href: 'https://github.com/DahalRojan',
    label: t('footer.github'),
    external: true,
  },
  { href: 'mailto:rojandahal1026@gmail.com', label: t('footer.email') },
];
---

<footer class="mt-32 border-t border-[var(--color-rule)]">
  <div class="container-x flex flex-col gap-6 py-10 sm:flex-row sm:items-baseline sm:justify-between">
    <p class="text-[14px] text-[var(--color-ink-soft)]">
      &copy; {year} Rojan Dahal. {t('footer.builtIn.before')}<span class="display-italic">{t('footer.builtIn.place')}</span>{t('footer.builtIn.after')}
    </p>
    <ul class="flex flex-wrap gap-x-6 gap-y-2 text-[14px] uppercase tracking-[0.14em] text-[var(--color-ink-soft)]">
      {
        links.map(({ href, label, external }) => (
          <li>
            <a
              href={href}
              class="link-grow hover:text-[var(--color-ink)]"
              {...(external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
            >
              {label}
            </a>
          </li>
        ))
      }
    </ul>
  </div>
</footer>
