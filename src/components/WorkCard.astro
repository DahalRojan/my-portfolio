---
interface Props {
  href: string;
  title: string;
  role: string;
  period: string;
  summary: string;
  stack?: string[];
}

const { href, title, role, period, summary, stack = [] } = Astro.props;
---

<a
  href={href}
  class="group block border-t border-[var(--color-rule)] py-7"
  data-reveal
>
  <div class="flex flex-col gap-3 sm:flex-row sm:items-baseline sm:gap-10">
    <div class="mono shrink-0 text-[13px] uppercase tracking-[0.14em] text-[var(--color-ink-faint)] sm:w-32">
      {period}
    </div>

    <div class="flex-1">
      <div class="flex flex-wrap items-baseline gap-x-3">
        <h3 class="display text-[clamp(1.4rem,1.5vw+0.8rem,1.85rem)] leading-tight transition-colors group-hover:text-[var(--color-rust)]">
          {title}
        </h3>
        <span class="mono text-[13px] uppercase tracking-[0.14em] text-[var(--color-ink-faint)]">
          &middot; {role}
        </span>
      </div>

      <p class="mt-2 text-[16px] leading-snug text-[var(--color-ink-soft)]">
        {summary}
      </p>

      {
        stack.length > 0 && (
          <ul class="mono mt-3 flex flex-wrap gap-x-4 gap-y-1 text-[12px] uppercase tracking-[0.14em] text-[var(--color-ink-faint)]">
            {stack.map((s) => (
              <li>&middot; {s}</li>
            ))}
          </ul>
        )
      }
    </div>

    <span
      class="mono shrink-0 text-[13px] uppercase tracking-[0.14em] text-[var(--color-ink-faint)] transition-colors group-hover:text-[var(--color-rust)] sm:self-baseline"
    >
      Case study &rarr;
    </span>
  </div>
</a>
