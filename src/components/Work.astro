---
import SectionPanel from "./SectionPanel.astro";
import CaseCard from "./CaseCard.astro";
import { cases } from "../content/cases";
---
<SectionPanel
  id="inference"
  number="03"
  label="Inference"
  kicker="L3 — the work that the rest of the site is downstream of"
  title="Four roles. One through-line: production AI that has to behave."
>
  <div class="cases">
    {cases.map((c, i) => <CaseCard case={c} index={i} />)}
  </div>
</SectionPanel>

<style>
  .cases { display: grid; }
</style>
