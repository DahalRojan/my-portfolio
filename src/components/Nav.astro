---
const { pathname } = Astro.url;
const isActive = (href: string) =>
  href === '/'
    ? pathname === '/'
    : pathname === href || pathname.startsWith(href + '/');

const links = [
  { href: '/writing', label: 'Writing' },
  { href: '/work', label: 'Work' },
  { href: '/about', label: 'About' },
];
---

<header class="border-b border-[var(--color-rule)]">
  <div class="container-x flex items-baseline justify-between py-5">
    <a href="/" class="display text-[1.5rem] leading-none tracking-tight link-grow">
      Rojan Dahal
    </a>

    <nav aria-label="Primary">
      <ul class="flex items-baseline gap-7 text-[14px] uppercase tracking-[0.14em]">
        {
          links.map(({ href, label }) => (
            <li>
              <a
                href={href}
                class:list={[
                  'link-grow',
                  isActive(href)
                    ? 'text-[var(--color-rust)]'
                    : 'text-[var(--color-ink-soft)] hover:text-[var(--color-ink)]',
                ]}
              >
                {label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>
  </div>
</header>
